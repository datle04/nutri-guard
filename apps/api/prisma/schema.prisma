generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── TẦNG 1: DỮ LIỆU TĨNH ──

model Food {
  id          String        @id @default(cuid())
  name        String
  nameSearch  String
  category    FoodCategory
  description String?
  imageUrl    String?
  servingSize Int           @default(100)
  nutrients   FoodNutrient[]
  mealItems   MealLogItem[]
  createdAt   DateTime      @default(now())

  @@index([nameSearch])
  @@index([category])
}

enum FoodCategory {
  RICE_NOODLE
  MEAT
  SEAFOOD
  VEGETABLE
  FRUIT
  SOUP
  DESSERT
  BEVERAGE
  SNACK
  OTHER
}

model Nutrient {
  id    String         @id @default(cuid())
  name  String         @unique
  unit  String
  foods FoodNutrient[]
  rules AlertRule[]
}

model FoodNutrient {
  id         String   @id @default(cuid())
  food       Food     @relation(fields: [foodId], references: [id])
  foodId     String
  nutrient   Nutrient @relation(fields: [nutrientId], references: [id])
  nutrientId String
  amount     Float

  @@unique([foodId, nutrientId])
  @@index([foodId])
  @@index([nutrientId])
}

model Condition {
  id          String          @id @default(cuid())
  name        String          @unique
  description String?
  alertRules  AlertRule[]
  users       UserCondition[]
}

model AlertRule {
  id          String        @id @default(cuid())
  condition   Condition     @relation(fields: [conditionId], references: [id])
  conditionId String
  nutrient    Nutrient      @relation(fields: [nutrientId], references: [id])
  nutrientId  String
  maxAmount   Float
  severity    AlertSeverity
  message     String

  @@unique([conditionId, nutrientId])
}

enum AlertSeverity {
  DANGER
  WARNING
  INFO
}

// ── TẦNG 2: DỮ LIỆU NGƯỜI DÙNG ──

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  passwordHash  String
  name          String
  avatarUrl     String?
  profile       HealthProfile?
  conditions    UserCondition[]
  mealLogs      MealLog[]
  healthMetrics HealthMetric[]
  chatSessions  ChatSession[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model HealthProfile {
  id             String        @id @default(cuid())
  user           User          @relation(fields: [userId], references: [id])
  userId         String        @unique
  age            Int
  gender         Gender
  heightCm       Float
  weightKg       Float
  bmi            Float
  targetCalories Int
  goal           NutritionGoal
  updatedAt      DateTime      @updatedAt
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum NutritionGoal {
  LOSE_WEIGHT
  MAINTAIN
  GAIN_WEIGHT
  CONTROL_BLOOD_SUGAR
}

model UserCondition {
  id          String    @id @default(cuid())
  user        User      @relation(fields: [userId], references: [id])
  userId      String
  condition   Condition @relation(fields: [conditionId], references: [id])
  conditionId String
  diagnosedAt DateTime?
  notes       String?

  @@unique([userId, conditionId])
}

model MealLog {
  id       String        @id @default(cuid())
  user     User          @relation(fields: [userId], references: [id])
  userId   String
  mealType MealType
  loggedAt DateTime      @default(now())
  imageUrl String?
  notes    String?
  items    MealLogItem[]

  @@index([userId, loggedAt])
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

model MealLogItem {
  id        String  @id @default(cuid())
  mealLog   MealLog @relation(fields: [mealLogId], references: [id], onDelete: Cascade)
  mealLogId String
  food      Food    @relation(fields: [foodId], references: [id])
  foodId    String
  grams     Float
}

model HealthMetric {
  id         String     @id @default(cuid())
  user       User       @relation(fields: [userId], references: [id])
  userId     String
  type       MetricType
  value      Float
  measuredAt DateTime   @default(now())
  notes      String?

  @@index([userId, type, measuredAt])
}

enum MetricType {
  BLOOD_SUGAR_FASTING
  BLOOD_SUGAR_AFTER
  BLOOD_PRESSURE_SYS
  BLOOD_PRESSURE_DIA
  URIC_ACID
  CHOLESTEROL_TOTAL
  CHOLESTEROL_LDL
  CHOLESTEROL_HDL
  WEIGHT
}

model ChatSession {
  id        String        @id @default(cuid())
  user      User          @relation(fields: [userId], references: [id])
  userId    String
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
}

model ChatMessage {
  id        String      @id @default(cuid())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String
  role      MessageRole
  content   String
  createdAt DateTime    @default(now())
}

enum MessageRole {
  USER
  ASSISTANT
}
